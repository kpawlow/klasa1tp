-- ===============================
-- BAZA DANYCH: komputery
-- ===============================

DROP DATABASE IF EXISTS komputery;
CREATE DATABASE komputery CHARACTER SET utf8mb4 COLLATE utf8mb4_polish_ci;
USE komputery;

-- ===============================
-- TABELA: komputery
-- ===============================
CREATE TABLE komputery (
    id_komputera INT AUTO_INCREMENT PRIMARY KEY,
    nazwa VARCHAR(100) NOT NULL,
    producent VARCHAR(50) NOT NULL
);

-- ===============================
-- TABELA: podzespoly
-- ===============================
CREATE TABLE podzespoly (
    id_podzespolu INT AUTO_INCREMENT PRIMARY KEY,
    nazwa VARCHAR(100) NOT NULL,
    typ VARCHAR(50) NOT NULL,          -- Procesor, RAM, Płyta główna
    producent VARCHAR(50) NOT NULL
);

-- ===============================
-- TABELA: kompatybilnosc
-- ===============================
CREATE TABLE kompatybilnosc (
    id_komputera INT NOT NULL,
    id_podzespolu INT NOT NULL,
    PRIMARY KEY (id_komputera, id_podzespolu),
    FOREIGN KEY (id_komputera) REFERENCES komputery(id_komputera)
        ON DELETE CASCADE,
    FOREIGN KEY (id_podzespolu) REFERENCES podzespoly(id_podzespolu)
        ON DELETE CASCADE
);

