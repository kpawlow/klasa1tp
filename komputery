-- ===============================
-- ZAPYTANIA Z JOIN
-- ===============================

-- 1. Lista komputerów i kompatybilnych podzespołów
SELECT k.nazwa AS komputer, p.nazwa AS podzespol, p.typ
FROM kompatybilnosc kp
JOIN komputery k ON kp.id_komputera = k.id_komputera
JOIN podzespoly p ON kp.id_podzespolu = p.id_podzespolu;

-- 2. Podzespoły kompatybilne z komputerem "GamingPro"
SELECT p.nazwa, p.typ
FROM kompatybilnosc kp
JOIN komputery k ON kp.id_komputera = k.id_komputera
JOIN podzespoly p ON kp.id_podzespolu = p.id_podzespolu
WHERE k.nazwa = 'GamingPro';

-- 3. Komputery obsługujące procesory
SELECT DISTINCT k.nazwa
FROM kompatybilnosc kp
JOIN komputery k ON kp.id_komputera = k.id_komputera
JOIN podzespoly p ON kp.id_podzespolu = p.id_podzespolu
WHERE p.typ = 'Procesor';

-- 4. Komputery i producenci ich podzespołów
SELECT k.nazwa AS komputer, p.producent AS producent_podzespolu
FROM kompatybilnosc kp
JOIN komputery k ON kp.id_komputera = k.id_komputera
JOIN podzespoly p ON kp.id_podzespolu = p.id_podzespolu;

-- 5. Liczba kompatybilnych podzespołów dla każdego komputera
SELECT k.nazwa, COUNT(p.id_podzespolu) AS liczba_podzespolow
FROM kompatybilnosc kp
JOIN komputery k ON kp.id_komputera = k.id_komputera
JOIN podzespoly p ON kp.id_podzespolu = p.id_podzespolu
GROUP BY k.nazwa;
